# Runa Self-Hosted Configuration
# Generate secrets with: openssl rand -hex 32

# Required — generate each with: openssl rand -hex 32
DB_PASSWORD=changeme
AUTH_SECRET=changeme

# OAuth client credentials — Gatekeeper auto-creates the client on first boot
# using these values, and runa-app uses them to authenticate
AUTH_CLIENT_ID=changeme
AUTH_CLIENT_SECRET=changeme

# Optional overrides
# APP_PORT=3000
# API_PORT=4000
# AUTH_PORT=3001
# DB_PORT=5432

# Optional: email delivery for account verification
# Without SMTP, verification URLs are logged to the auth container's stdout
# SENDER_EMAIL_ADDRESS=noreply@example.com
